{
  "name": "train-ticket-app",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm --filter @train-ticket/core test",
    "dev:mobile": "pnpm --filter @train-ticket/mobile dev",
    "dev:cli": "pnpm --filter @train-ticket/cli cli",
    "build:mobile": "pnpm --filter @train-ticket/mobile build",
    "build:core": "pnpm --filter @train-ticket/core build",
    "build:cli": "pnpm --filter @train-ticket/cli build"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
